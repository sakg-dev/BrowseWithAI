{
    "manifest_version": 3,
    "name": "BrowseWithAI",
    "version": "0.0.1",
    "description": "Browse With AI without moving tabs much!",
    "content_scripts": [
        {
            "js": ["content.js"],
            "matches": ["<all_urls>"]
        }
    ],
    "background": {
        "service_worker": "background.js"
    },
    "icons": {
        "16": "icons/icon16.png",
        "32": "icons/icon32.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}